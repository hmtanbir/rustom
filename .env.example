# API Server Configuration
PORT=8080
HOST=0.0.0.0
RUST_LOG=info,rustom=debug,tower_http=debug

# Database Configuration
DATABASE_URL=postgres://postgres:postgres@localhost:5432/rustom_development

# Redis Configuration
REDIS_URL=redis://127.0.0.1:6379/0

# RabbitMQ Configuration
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672/%2f

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_must_be_at_least_32_characters_long
JWT_EXPIRATION_SECONDS=86400

# API Security and Encryption Configuration
API_PAYLOAD_ENCRYPTION_ENABLED=true
API_GATEWAY_KEY="api-gateway-key"
API_ENCRYPTION_KEY="api-encryption-key"

# Slack Configuration
SLACK_WEBHOOK_URL=
SLACK_ERROR_WEBHOOK_URL=
SLACK_REGISTRATION_WEBHOOK_URL=
